# Copy to `.streamlit/secrets.toml` (do not commit real secrets).

# --- Google Sheet dedicated to fitness (create a new sheet recommended) ---
FITNESS_SPREADSHEET_ID = "paste-spreadsheet-id-from-url"
# Optional: worksheet tab name for meal rows (default: Meals)
# FITNESS_MEALS_WORKSHEET = "Meals"

# Tab for food keywords → CATEGORY / SUBCATEGORY (like finance "Mappings").
# Use the exact tab **name** from the sheet UI — not the gid= from the URL.
# Example spreadsheet: docs.google.com/spreadsheets/d/1cdH2U_HiuHLlX8nilqrUzsqCmrkAbsvpqpr7w6QtQGU/...
# FITNESS_FOOD_MAPPINGS_WORKSHEET = "YourTabName"

# --- Upstash Redis REST (same pattern as finance-dashboard) ---
UPSTASH_REDIS_REST_URL = "https://YOUR-REGION.upstash.io"
UPSTASH_REDIS_REST_TOKEN = "YOUR_TOKEN"

# --- Google service account JSON (same as finance-dashboard) ---
# Option A: nested table
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = """-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"""
# client_email = "..."
# ...

# Option B: path to JSON file
# GOOGLE_SHEETS_CREDENTIALS_FILE = "/absolute/path/to/service-account.json"
